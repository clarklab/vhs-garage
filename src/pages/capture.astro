---
import Base from '../layouts/Base.astro';
---

<Base title="Capture" description="A browser-based VHS digitization station.">

  <style>
    .rec-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      border: 2px solid #e53935;
      background: transparent;
      cursor: pointer;
      transition: background 0.2s;
    }
    .rec-btn:hover { background: rgba(229, 57, 53, 0.1); }
    .rec-btn .rec-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #e53935;
    }
    .rec-btn .rec-label {
      font-family: monospace;
      font-size: 14px;
      font-weight: bold;
      color: #e53935;
      letter-spacing: 0.08em;
    }
    .rec-btn.recording .rec-dot {
      animation: rec-blink 0.8s steps(1) infinite;
    }
    @keyframes rec-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    .ai-loader::after {
      content: '░░░░░▒▓█░';
      animation: ai-scan 1.2s steps(1) infinite;
    }
    @keyframes ai-scan {
      0%   { content: '░░░░░▒▓█░'; }
      12%  { content: '█░░░░░▒▓█'; }
      25%  { content: '▓█░░░░░▒▓'; }
      37%  { content: '▒▓█░░░░░▒'; }
      50%  { content: '░▒▓█░░░░░'; }
      62%  { content: '░░▒▓█░░░░'; }
      75%  { content: '░░░▒▓█░░░'; }
      87%  { content: '░░░░▒▓█░░'; }
    }
    #preview-container.recording-active {
      border: 3px solid #e53935;
      box-shadow: inset 0 0 30px rgba(229, 57, 53, 0.15);
    }
    #rec-overlay-timer {
      font-size: 2rem;
      letter-spacing: 0.05em;
    }
    .scanlines {
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.08) 2px,
        rgba(0, 0, 0, 0.08) 4px
      );
      pointer-events: none;
    }
  </style>

  <!-- Browser check -->
  <div id="browser-check" class="hidden fixed inset-0 z-50 bg-black flex items-center justify-center p-8">
    <div class="max-w-md text-center">
      <p class="text-2xl mb-4">VHS Capture requires Chrome</p>
      <p class="text-gray-400 text-sm">This app uses the File System Access API to write recordings directly to disk. This API is only available in Chrome.</p>
    </div>
  </div>

  <!-- Two-column grid -->
  <div id="capture-app" class="h-screen flex flex-col p-4 max-w-7xl mx-auto">
    <div class="flex-1 grid md:grid-cols-[1fr_340px] gap-4 min-h-0">

      <!-- Left: Main Capture -->
      <div class="flex flex-col min-h-0">
        <!-- Preview tabs -->
        <div id="preview-tabs" class="flex gap-0 text-xs mb-0">
          <button id="tab-live" class="px-3 py-1 border border-white/20 border-b-0 text-white/70 bg-[#141214]">Live</button>
          <button id="tab-playback" class="hidden px-3 py-1 border border-white/10 border-b-0 text-white/30 bg-black hover:text-white/50">Last Recording</button>
        </div>
        <!-- Preview -->
        <div id="preview-container" class="relative flex-1 bg-[#141214] border border-white/10 overflow-hidden cursor-pointer">
          <video id="preview" autoplay playsinline muted class="w-full h-full object-contain bg-black"></video>
          <video id="playback" controls class="hidden w-full h-full object-contain bg-black"></video>
          <div class="scanlines absolute inset-0"></div>
          <div id="rec-overlay-timer" class="hidden absolute top-3 right-4 text-red-500 tabular-nums z-10" style="text-shadow: 0 0 10px rgba(229,57,53,0.7), 0 0 20px rgba(229,57,53,0.4);">
            00:00:00
          </div>
          <!-- Shown when no device selected -->
          <div id="no-signal" class="absolute inset-0 flex items-center justify-center">
            <div class="text-center">
              <p class="text-white/50 text-sm mb-2">No capture device</p>
              <p class="text-white/70 text-xs">Click to select</p>
            </div>
          </div>
          <!-- Inline device selector (hidden by default) -->
          <div id="device-selector" class="hidden absolute inset-0 bg-black/90 flex items-center justify-center">
            <div class="w-64">
              <p class="text-sm mb-3">Select capture device</p>
              <select id="select-video" class="w-full bg-black border border-white/30 text-white text-xs p-2 mb-2"></select>
              <select id="select-audio" class="w-full bg-black border border-white/30 text-white text-xs p-2 mb-3"></select>
              <button id="select-video-ok" class="w-full py-2 border border-white/30 text-white/60 hover:text-white text-xs">Connect</button>
            </div>
          </div>
        </div>

        <!-- Audio spectrum meter -->
        <canvas id="audio-meter" class="w-full h-6 mt-1" style="image-rendering: pixelated;"></canvas>

        <!-- Controls below preview -->
        <div class="py-3">
          <div class="flex items-center gap-4 mb-3">
            <button id="rec-btn" class="rec-btn shrink-0" title="Record">
              <span class="rec-dot"></span><span class="rec-label">REC</span>
            </button>
            <div class="flex-1">
              <div class="flex items-baseline gap-3">
                <span id="rec-timer" class="text-xl tabular-nums">00:00:00</span>
                <span id="rec-size" class="text-xs text-gray-400">0.0 MB</span>
              </div>
            </div>
          </div>
          <div class="flex items-center text-xs gap-3">
            <button id="to-library-btn" class="text-white/60 hover:text-white/80 transition-colors">View Library →</button>
            <button id="delete-recording-btn" class="hidden text-red-500 hover:text-red-400 transition-colors">Delete Recording</button>
          </div>
        </div>
      </div>

      <!-- Right: Sidebar -->
      <div class="flex flex-col gap-4 min-h-0 overflow-y-auto">

        <!-- Sleeve Capture -->
        <fieldset class="border border-white/20 p-3">
          <legend class="text-white/70 text-xs px-2">░ VHS Sleeve ░</legend>

          <!-- Capture view: webcam + shutter -->
          <div id="sleeve-capture-view">
            <div id="webcam-container" class="relative bg-[#141214] border border-white/10 aspect-[4/3] overflow-hidden cursor-pointer mb-3">
              <video id="sleeve-webcam" autoplay playsinline muted class="w-full h-full object-contain bg-black"></video>
              <!-- Translucent VHS case target overlay -->
              <div id="sleeve-target" class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <div class="aspect-[17/30] h-[70%] border-2 border-white/25 rounded-lg flex items-end justify-center pb-2">
                  <span class="text-white/20 text-[10px]">Position sleeve here</span>
                </div>
              </div>
              <!-- No webcam placeholder -->
              <div id="no-webcam" class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <p class="text-white/50 text-xs mb-1">No webcam</p>
                  <p class="text-white/70 text-[10px]">Click to select</p>
                </div>
              </div>
              <!-- Inline webcam selector -->
              <div id="webcam-selector" class="hidden absolute inset-0 bg-black/90 flex items-center justify-center">
                <div class="w-48">
                  <p class="text-xs mb-2">Select webcam</p>
                  <select id="select-webcam" class="w-full bg-black border border-white/30 text-white text-xs p-2 mb-2"></select>
                  <button id="select-webcam-ok" class="w-full py-1 border border-white/30 text-white/60 hover:text-white text-xs">Connect</button>
                </div>
              </div>
            </div>
            <button id="sleeve-capture-btn" class="w-full py-2 border border-white/30 text-white/60 hover:text-white hover:border-white/60 transition-colors text-xs">
              <span id="sleeve-capture-label">Capture Front</span>
            </button>
          </div>

          <!-- Review view: side-by-side previews + retake -->
          <div id="sleeve-review-view" class="hidden">
            <div class="grid grid-cols-2 gap-2 mb-2">
              <div class="text-center">
                <div id="sleeve-front-preview" class="aspect-[4/3] bg-[#141214] border border-white/10 flex items-center justify-center text-white/10 text-[10px] mb-1">--</div>
                <span id="sleeve-front-status" class="text-[10px] text-white/50">Front</span>
              </div>
              <div class="text-center">
                <div id="sleeve-back-preview" class="aspect-[4/3] bg-[#141214] border border-white/10 flex items-center justify-center text-white/10 text-[10px] mb-1">--</div>
                <span id="sleeve-back-status" class="text-[10px] text-white/50">Back</span>
              </div>
            </div>
            <button id="sleeve-retake-btn" class="w-full py-2 border border-white/30 text-white/60 hover:text-white hover:border-white/60 transition-colors text-xs">Retake</button>
          </div>
        </fieldset>

        <!-- Clip Info -->
        <fieldset class="border border-white/20 p-3">
          <legend class="text-white/70 text-xs px-2">░ Clip Info ░</legend>
          <div id="clip-info-fields" class="space-y-2 text-xs">
            <div>
              <label class="text-gray-400 block mb-1">Title</label>
              <input id="clip-title" type="text" placeholder="My Home Videos 1994"
                class="w-full px-2 py-1 bg-black border border-white/20 text-white text-xs placeholder-white/25 focus:outline-none focus:border-white/40" />
            </div>
            <div>
              <label class="text-gray-400 block mb-1">Description</label>
              <textarea id="clip-description" rows="2" placeholder="What's on this clip..."
                class="w-full px-2 py-1 bg-black border border-white/20 text-white text-xs placeholder-white/25 focus:outline-none focus:border-white/40 resize-none"></textarea>
            </div>
            <div id="ai-fields" class="space-y-2">
              <div id="clip-info-loader" class="hidden py-4 text-center text-white/40 text-sm ai-loader"></div>
              <div>
                <label class="text-gray-400 block mb-1">Year</label>
                <input id="clip-year" type="text" placeholder="1994"
                  class="w-full px-2 py-1 bg-black border border-white/20 text-white text-xs placeholder-white/25 focus:outline-none focus:border-white/40" />
              </div>
              <div>
                <label class="text-gray-400 block mb-1">Tags</label>
                <input id="clip-tags" type="text" placeholder="home video, 90s, family"
                  class="w-full px-2 py-1 bg-black border border-white/20 text-white text-xs placeholder-white/25 focus:outline-none focus:border-white/40" />
              </div>
              <div>
                <label class="text-gray-400 block mb-1">VHS Tape</label>
                <input id="clip-tape" type="text" placeholder="Which tape is this from?"
                  class="w-full px-2 py-1 bg-black border border-white/20 text-white text-xs placeholder-white/25 focus:outline-none focus:border-white/40" />
              </div>
              <div>
                <label class="text-gray-400 block mb-1">Cassette Notes</label>
                <textarea id="clip-notes" rows="2" placeholder="Special edition, director's cut, recording speed..."
                  class="w-full px-2 py-1 bg-black border border-white/20 text-white text-xs placeholder-white/25 focus:outline-none focus:border-white/40 resize-none"></textarea>
              </div>
            </div>
          </div>
        </fieldset>
      </div>
    </div>

    <!-- Bottom status bar -->
    <div id="status-bar" class="flex items-center gap-4 py-2 text-[10px] text-white/50 border-t border-white/10 mt-2 cursor-pointer hover:text-white/70 transition-colors">
      <span>Video: <span id="status-video-label">—</span> <span id="status-video-dot" style="color:#f44336;">░</span></span>
      <span>Audio: <span id="status-audio-label">—</span> <span id="status-audio-dot" style="color:#f44336;">░</span></span>
      <span>Webcam: <span id="status-webcam-label">—</span> <span id="status-webcam-dot" style="color:#f44336;">░</span></span>
      <span id="status-dir-label">No save folder</span>
      <span class="ml-auto">⚙</span>
    </div>

    <!-- Device settings popover (triggered by clicking status bar) -->
    <div id="device-popover" class="hidden fixed bottom-10 left-4 right-4 z-30 max-w-xl mx-auto bg-black/95 border border-white/20 p-4 text-xs">
      <div class="flex items-center justify-between mb-3">
        <span class="text-white/70">Device Settings</span>
        <button id="device-popover-close" class="text-white/50 hover:text-white/70 transition-colors">Close</button>
      </div>
      <div class="grid md:grid-cols-2 gap-3">
        <div>
          <label class="text-gray-400 block mb-1">Video Source</label>
          <select id="dp-video" class="w-full bg-black border border-white/20 text-white text-xs p-1.5"></select>
        </div>
        <div>
          <label class="text-gray-400 block mb-1">Audio Source</label>
          <select id="dp-audio" class="w-full bg-black border border-white/20 text-white text-xs p-1.5"></select>
        </div>
        <div>
          <label class="text-gray-400 block mb-1">Webcam</label>
          <select id="dp-webcam" class="w-full bg-black border border-white/20 text-white text-xs p-1.5"></select>
        </div>
        <div>
          <label class="text-gray-400 block mb-1">Save Location</label>
          <button id="dp-pick-dir" class="w-full py-1.5 border border-white/20 text-white/60 hover:text-white text-left px-2">
            <span id="dp-dir-name">Choose folder...</span>
          </button>
        </div>
      </div>
      <div class="mt-3 flex justify-end">
        <button id="dp-apply" class="px-4 py-1.5 border border-white/30 text-white/60 hover:text-white hover:border-white/60 transition-colors">Apply</button>
      </div>
    </div>
  </div>

  <!-- Library view (full page overlay, toggled) -->
  <div id="view-library" class="hidden fixed inset-0 z-30 bg-black p-4 overflow-y-auto">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between mb-4">
        <button id="to-capture-btn" class="text-xs text-white/60 hover:text-white/80">← Back to Capture</button>
        <button id="export-catalog-btn" class="text-xs text-white/60 hover:text-white/80">Export catalog.json</button>
      </div>
      <div id="library-grid" class="grid grid-cols-2 md:grid-cols-3 gap-4"></div>
      <p id="library-empty" class="text-gray-400 text-sm text-center py-12">No clips captured yet.</p>
    </div>
  </div>

  <!-- Settings popover (hidden, triggered by gear icon) -->
  <div id="settings-popover" class="hidden fixed bottom-10 right-4 z-30 bg-black/95 border border-white/20 p-3 w-56 text-xs">
    <div class="space-y-3">
      <div>
        <label class="text-gray-400 block mb-1">Recording Quality</label>
        <select id="setting-quality" class="w-full bg-black border border-white/20 text-white text-xs p-1">
          <option value="8000000">Archival (8 Mbps)</option>
          <option value="5000000" selected>High (5 Mbps)</option>
          <option value="2500000">Standard (2.5 Mbps)</option>
        </select>
      </div>
      <div>
        <label class="text-gray-400 block mb-1">Video Format</label>
        <select id="setting-format" class="w-full bg-black border border-white/20 text-white text-xs p-1">
          <option value="mp4" selected>MP4 (H.264)</option>
          <option value="webm">WebM (VP9)</option>
        </select>
      </div>
      <div>
        <label class="text-gray-400 block mb-1">File naming</label>
        <select id="setting-name-format" class="w-full bg-black border border-white/20 text-white text-xs p-1">
          <option value="title">Title + timestamp</option>
          <option value="timestamp">Timestamp only</option>
        </select>
      </div>
      <div>
        <button id="setting-pick-dir" class="w-full py-1 border border-white/20 text-white/60 hover:text-white text-left px-2">
          <span id="setting-dir-name">Choose save folder...</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Hidden canvas for thumbnails and sleeve captures -->
  <canvas id="capture-canvas" class="hidden"></canvas>

  <script type="module" src="/scripts/capture/app.js"></script>

</Base>
